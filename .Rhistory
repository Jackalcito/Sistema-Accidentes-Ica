# ============================================================
# SISTEMA DE ANÁLISIS DE ACCIDENTES DE TRÁNSITO - ICA, PERÚ
# Curso: Análisis y Diseño de Sistemas - UNICA 2026
# Fuente: MTC / ONSV - Observatorio Nacional de Seguridad Vial
# Datos reales: 2015-2024
# ============================================================
# 1. LIBRERÍAS
# install.packages(c("readxl", "dplyr", "ggplot2", "tidyr"))
library(readxl)
library(dplyr)
library(ggplot2)
library(tidyr)
# ============================================================
# 2. CARGAR ARCHIVO 1: Accidentes por departamento 2015-2024 (MTC)
# ============================================================
df_mtc <- read_excel("6966856-accidentes-de-transito-registrado-segun-departamento-2015-2024.xlsx",
skip = 3)
colnames(df_mtc)[1] <- "DEPARTAMENTO"
# Filtrar solo Ica
ica_hist <- df_mtc %>% filter(DEPARTAMENTO == "Ica")
# Convertir a formato largo para graficar
ica_largo <- ica_hist %>%
pivot_longer(cols = -DEPARTAMENTO,
names_to = "Año",
values_to = "Accidentes") %>%
mutate(Año = as.integer(Año))
cat("📊 ACCIDENTES EN ICA POR AÑO (2015-2024)\n")
cat("══════════════════════════════════════════\n")
print(ica_largo)
# ============================================================
# 3. GRÁFICO 1 - Tendencia histórica de accidentes en Ica
# ============================================================
g1 <- ggplot(ica_largo, aes(x = Año, y = Accidentes)) +
geom_line(color = "#E63946", linewidth = 1.5) +
geom_point(color = "#E63946", size = 3) +
geom_label(aes(label = Accidentes), vjust = -0.5, size = 3.2,
fill = "white", color = "#E63946") +
scale_x_continuous(breaks = 2015:2024) +
labs(
title    = "Evolución de Accidentes de Tránsito en Ica",
subtitle = "2015 - 2024 | Fuente: MTC - Dirección General de Autorizaciones",
x        = "Año",
y        = "N° de Accidentes"
) +
theme_minimal(base_size = 12) +
theme(
plot.title    = element_text(face = "bold", size = 14),
axis.text.x   = element_text(angle = 45, hjust = 1)
)
print(g1)
# ============================================================
# 4. CARGAR ARCHIVO 2: BBDD ONSV - Personas en siniestros fatales
# ============================================================
df_onsv <- read_excel("BBDD ONSV - PERSONAS 2021-2025 (preliminar).xlsx",
skip = 4)
# Limpiar nombres de columnas
colnames(df_onsv) <- trimws(colnames(df_onsv))
# Filtrar solo Ica
ica <- df_onsv %>% filter(DEPARTAMENTO == "ICA")
cat("\n📍 PERSONAS INVOLUCRADAS EN SINIESTROS FATALES EN ICA\n")
cat("══════════════════════════════════════════════════════\n")
cat("Total registros (2021-2025): ", nrow(ica), "\n")
cat("Masculino:  ", sum(ica$SEXO == "MASCULINO", na.rm = TRUE), "\n")
cat("Femenino:   ", sum(ica$SEXO == "FEMENINO", na.rm = TRUE), "\n")
# ============================================================
# 5. TABLA: Accidentes por año (ONSV)
# ============================================================
tabla_año <- ica %>%
group_by(AÑO) %>%
summarise(Personas = n()) %>%
arrange(AÑO)
cat("\n📅 PERSONAS INVOLUCRADAS POR AÑO:\n")
print(tabla_año)
# ============================================================
# 6. GRÁFICO 2 - Personas involucradas por año en Ica
# ============================================================
g2 <- ggplot(tabla_año, aes(x = factor(AÑO), y = Personas)) +
geom_bar(stat = "identity", fill = "#457B9D", width = 0.6) +
geom_text(aes(label = Personas), vjust = -0.5, fontface = "bold") +
labs(
title    = "Personas Involucradas en Siniestros Fatales en Ica",
subtitle = "2021 - 2025 | Fuente: ONSV / PNP",
x        = "Año",
y        = "N° de Personas"
) +
theme_minimal(base_size = 12) +
theme(plot.title = element_text(face = "bold", size = 14))
print(g2)
# ============================================================
# 7. TABLA + GRÁFICO 3 - Tipo de siniestro (choque, atropello, etc.)
# ============================================================
tabla_clase <- ica %>%
group_by(`CLASE DE SINIESTRO`) %>%
summarise(Casos = n()) %>%
arrange(desc(Casos))
cat("\n🚗 TIPO DE SINIESTRO EN ICA:\n")
print(tabla_clase)
g3 <- ggplot(tabla_clase, aes(x = reorder(`CLASE DE SINIESTRO`, Casos),
y = Casos)) +
geom_bar(stat = "identity", fill = "#2A9D8F") +
geom_text(aes(label = Casos), hjust = -0.2, fontface = "bold") +
coord_flip() +
labs(
title    = "Tipos de Siniestros de Tránsito en Ica",
subtitle = "2021 - 2025 | Fuente: ONSV / PNP",
x        = "Tipo de Siniestro",
y        = "N° de Casos"
) +
theme_minimal(base_size = 12) +
theme(plot.title = element_text(face = "bold", size = 14))
print(g3)
# ============================================================
# 8. GRÁFICO 4 - Vehículos más involucrados
# ============================================================
tabla_vehiculo <- ica %>%
group_by(VEHÍCULO) %>%
summarise(Casos = n()) %>%
arrange(desc(Casos)) %>%
head(8)
g4 <- ggplot(tabla_vehiculo, aes(x = reorder(VEHÍCULO, Casos), y = Casos)) +
geom_bar(stat = "identity", fill = "#F4A261") +
geom_text(aes(label = Casos), hjust = -0.2, fontface = "bold") +
coord_flip() +
labs(
title    = "Vehículos Más Involucrados en Siniestros en Ica",
subtitle = "2021 - 2025 | Fuente: ONSV / PNP",
x        = "Tipo de Vehículo",
y        = "N° de Casos"
) +
theme_minimal(base_size = 12) +
theme(plot.title = element_text(face = "bold", size = 14))
print(g4)
# ============================================================
# 9. GRÁFICO 5 - Causa del siniestro
# ============================================================
tabla_causa <- ica %>%
group_by(CAUSA) %>%
summarise(Casos = n()) %>%
arrange(desc(Casos))
g5 <- ggplot(tabla_causa, aes(x = reorder(CAUSA, Casos), y = Casos)) +
geom_bar(stat = "identity", fill = "#E76F51") +
geom_text(aes(label = Casos), hjust = -0.2, fontface = "bold") +
coord_flip() +
labs(
title    = "Causas de Siniestros de Tránsito en Ica",
subtitle = "2021 - 2025 | Fuente: ONSV / PNP",
x        = "Causa",
y        = "N° de Casos"
) +
theme_minimal(base_size = 12) +
theme(plot.title = element_text(face = "bold", size = 14))
print(g5)
# ============================================================
# 10. ESTADÍSTICAS DESCRIPTIVAS FINALES
# ============================================================
cat("\n📋 RESUMEN ESTADÍSTICO - ICA\n")
cat("══════════════════════════════════════════════════════\n")
cat("Período histórico (MTC):      2015 - 2024\n")
cat("Mínimo accidentes/año:       ", min(ica_largo$Accidentes), "(", ica_largo$Año[which.min(ica_largo$Accidentes)], ")\n")
cat("Máximo accidentes/año:       ", max(ica_largo$Accidentes), "(", ica_largo$Año[which.max(ica_largo$Accidentes)], ")\n")
cat("Promedio accidentes/año:     ", round(mean(ica_largo$Accidentes), 1), "\n")
cat("──────────────────────────────────────────────────────\n")
cat("Siniestros fatales (ONSV):    2021 - 2025\n")
cat("Total personas involucradas: ", nrow(ica), "\n")
cat("Siniestro más frecuente:     ", tabla_clase$`CLASE DE SINIESTRO`[1], "(", tabla_clase$Casos[1], "casos)\n")
cat("Vehículo más involucrado:    ", tabla_vehiculo$VEHÍCULO[1], "(", tabla_vehiculo$Casos[1], "casos)\n")
cat("══════════════════════════════════════════════════════\n")
cat("\nProblema identificado: El incremento sostenido de accidentes en Ica,\n")
cat("especialmente choques y atropellos, evidencia la necesidad urgente de\n")
cat("un sistema centralizado de análisis de siniestralidad vial.\n")
